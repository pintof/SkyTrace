  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "cross-env SERVER_MODE=api node --watch server/index.js",
    "build": "vite build",
